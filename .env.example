# Flask / Render configuration
SECRET_KEY=your-flask-secret-key-change-this
FLASK_ENV=development

# Supabase configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application settings
INSTITUTION_NAME=Thika Technical Training Institute
BUCKET_SCRIPTS=assessment-scripts
BUCKET_EVIDENCE=assessment-evidence
BUCKET_POE=poe-components
MAX_CONTENT_LENGTH=52428800
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,mp4,webm

# Notes:
# 1) Run combined_supabase.sql in Supabase SQL Editor before starting the app.
# 2) For Render deployment, set these variables in Render Dashboard instead of committing .env.
